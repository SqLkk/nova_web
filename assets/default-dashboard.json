{
  "version": "1.0",
  "name": "Default Dashboard",
  "description": "Varsayılan güç izleme dashboard'u",
  "widgets": [
    {
      "id": "voltage-a-widget",
      "instanceId": "widget_voltage_a_001",
      "title": "Gerilim A-N",
      "icon": "fas fa-bolt",
      "type": "value-card",
      "widgetType": "value-card",
      "dataSource": "voltage",
      "thresholds": { "warning": 235, "danger": 245, "unit": "V" },
      "layout": { "x": 0, "y": 0, "width": 1, "height": 1 },
      "category": "stats",
      "visible": true,
      "refreshRate": 2000,
      "description": "A fazı nötr arası gerilim değeri"
    },
    {
      "id": "voltage-unbalance-widget",
      "instanceId": "widget_voltage_unbalance_001",
      "title": "Gerilim Dengesizliği",
      "icon": "fas fa-balance-scale",
      "type": "value-card",
      "widgetType": "value-card",
      "dataSource": "voltage",
      "thresholds": { "warning": 2.5, "danger": 5, "unit": "%" },
      "layout": { "x": 1, "y": 0, "width": 1, "height": 1 },
      "category": "stats",
      "visible": true,
      "refreshRate": 2000,
      "description": "Fazlar arası gerilim dengesizlik oranı"
    },
    {
      "id": "frequency-widget",
      "instanceId": "widget_frequency_001",
      "title": "Frekans",
      "icon": "fas fa-wave-square",
      "type": "gauge",
      "widgetType": "gauge",
      "dataSource": "frequency",
      "thresholds": { "warning": 50.5, "danger": 51, "unit": "Hz" },
      "layout": { "x": 2, "y": 0, "width": 1, "height": 1 },
      "category": "gauges",
      "visible": true,
      "refreshRate": 1000,
      "description": "Sistem frekans değeri"
    },
    {
      "id": "energy-consumption-widget",
      "instanceId": "widget_energy_consumption_001",
      "title": "Enerji Tüketimi",
      "icon": "fas fa-plug",
      "type": "value-card",
      "widgetType": "value-card",
      "dataSource": "energy",
      "thresholds": { "warning": 1500, "danger": 2000, "unit": "kWh" },
      "layout": { "x": 0, "y": 1, "width": 1, "height": 1 },
      "category": "stats",
      "visible": true,
      "refreshRate": 5000,
      "description": "Toplam enerji tüketimi"
    },
    {
      "id": "power-factor-widget",
      "instanceId": "widget_power_factor_001",
      "title": "Güç Faktörü",
      "icon": "fas fa-percentage",
      "type": "value-card",
      "widgetType": "value-card",
      "dataSource": "power",
      "thresholds": { "warning": 0.85, "danger": 0.80, "unit": "" },
      "layout": { "x": 1, "y": 1, "width": 1, "height": 1 },
      "category": "stats",
      "visible": true,
      "refreshRate": 2000,
      "description": "Sistem güç faktörü"
    },
    {
      "id": "active-power-widget",
      "instanceId": "widget_active_power_001",
      "title": "Aktif Güç",
      "icon": "fas fa-bolt",
      "type": "value-card",
      "widgetType": "value-card",
      "dataSource": "power",
      "thresholds": { "warning": 1200, "danger": 1500, "unit": "W" },
      "layout": { "x": 2, "y": 1, "width": 1, "height": 1 },
      "category": "stats",
      "visible": true,
      "refreshRate": 2000,
      "description": "Sistem aktif güç değeri"
    },
    {
      "id": "energy-pie-chart-widget",
      "instanceId": "widget_energy_pie_001",
      "title": "Enerji Tüketimi Dağılımı",
      "icon": "fas fa-chart-pie",
      "type": "pie-chart",
      "widgetType": "pie-chart",
      "dataSource": "energy",
      "chartOptions": {
        "labels": ["Aydınlatma", "İklimlendirme", "Üretim", "Diğer"]
      },
      "layout": { "x": 0, "y": 2, "width": 2, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 10000,
      "description": "Enerji tüketiminin sektörlere göre dağılımı"
    },
    {
      "id": "power-bar-chart-widget",
      "instanceId": "widget_power_bar_001",
      "title": "Saatlik Güç Tüketimi",
      "icon": "fas fa-chart-bar",
      "type": "bar-chart",
      "widgetType": "bar-chart",
      "dataSource": "power",
      "thresholds": { "warning": 1200, "danger": 1500, "unit": "kW" },
      "layout": { "x": 2, "y": 2, "width": 2, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 5000,
      "description": "Saatlik güç tüketimi dağılımı"
    },
    {
      "id": "power-quality-radar-widget",
      "instanceId": "widget_power_quality_001",
      "title": "Güç Kalitesi Analizi",
      "icon": "fas fa-spider",
      "type": "radar-chart",
      "widgetType": "radar-chart",
      "dataSource": "power",
      "layout": { "x": 0, "y": 4, "width": 1, "height": 1 },
      "category": "charts",
      "visible": true,
      "refreshRate": 5000,
      "description": "Güç kalitesi parametrelerinin radar analizi"
    },
    {
      "id": "realtime-voltage-chart",
      "instanceId": "widget_realtime_voltage_001",
      "title": "Canlı Gerilim İzleme",
      "icon": "fas fa-chart-line",
      "type": "line-chart",
      "widgetType": "line-chart",
      "dataSource": "voltage",
      "thresholds": { "warning": 235, "danger": 245, "unit": "V" },
      "layout": { "x": 0, "y": 5, "width": 4, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 1000,
      "description": "Gerçek zamanlı gerilim trendi grafiği"
    },
    {
      "id": "realtime-frequency-chart",
      "instanceId": "widget_realtime_frequency_001",
      "title": "Canlı Frekans İzleme",
      "icon": "fas fa-wave-square",
      "type": "line-chart",
      "widgetType": "line-chart",
      "dataSource": "frequency",
      "thresholds": { "warning": 50.5, "danger": 51, "unit": "Hz" },
      "layout": { "x": 0, "y": 7, "width": 4, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 1000,
      "description": "Gerçek zamanlı frekans trendi grafiği"
    },
    {
      "id": "energy-distribution-widget",
      "instanceId": "widget_energy_distribution_001",
      "title": "Tüketim Dağılımı",
      "icon": "fas fa-chart-pie",
      "type": "pie-chart",
      "widgetType": "pie-chart",
      "dataSource": "energy",
      "layout": { "x": 0, "y": 4, "width": 2, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 5000,
      "description": "Enerji tüketim dağılım grafiği",
      "chartOptions": {
        "showLegend": true,
        "dataLabels": true,
        "series": [35, 25, 15, 25],
        "labels": ["Aydınlatma", "İklimlendirme", "Üretim", "Diğer"]
      }
    },
    {
      "id": "hourly-consumption-widget",
      "instanceId": "widget_hourly_consumption_001", 
      "title": "Saatlik Tüketim",
      "icon": "fas fa-chart-bar",
      "type": "bar-chart",
      "widgetType": "bar-chart",
      "dataSource": "power",
      "thresholds": { "warning": 1200, "danger": 1500, "unit": "kW" },
      "layout": { "x": 2, "y": 4, "width": 2, "height": 2 },
      "category": "charts", 
      "visible": true,
      "refreshRate": 5000,
      "description": "Saatlik güç tüketim grafiği",
      "chartOptions": {
        "categories": ["08:00", "10:00", "12:00", "14:00", "16:00", "18:00"],
        "series": [
          {"name": "Tüketim", "data": [980, 1150, 1340, 1220, 1310, 1170]}
        ]
      }
    },
    {
      "id": "realtime-chart-widget",
      "instanceId": "widget_realtime_chart_001",
      "title": "Canlı İzleme",
      "icon": "fas fa-chart-line",
      "type": "line-chart",
      "widgetType": "line-chart", 
      "dataSource": "realtime",
      "layout": { "x": 0, "y": 6, "width": 4, "height": 2 },
      "category": "charts",
      "visible": true,
      "refreshRate": 1000,
      "description": "Canlı gerilim ve frekans izleme",
      "thresholds": {
        "voltage": { "warning": 235, "danger": 245, "unit": "V" },
        "frequency": { "warning": 50.5, "danger": 51, "unit": "Hz" }
      }
    }
  ],
  "layout": {
    "gridColumns": 4,
    "gridRows": 10,
    "defaultWidgetWidth": 1,
    "defaultWidgetHeight": 1
  },
  "settings": {
    "refreshInterval": 2000,
    "autoRefresh": true,
    "theme": "dark",
    "showGrid": true
  }
}
